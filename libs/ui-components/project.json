{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@omnifex/ui-components",
  "projectType": "library",
  "sourceRoot": "libs/ui-components/src",

  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/ui-components"],
      "options": {
        "cwd": "libs/ui-components",
        "parallel": false,
        "commands": [
          "corepack pnpm run build",
          "node ../../tools/scripts/publish-ui-components.mjs"
        ]
      }
    },

    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/ui-components/**/*.{ts,tsx}"],
        "maxWarnings": 0
      }
    },

    "stylelint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "stylelint \"libs/ui-components/**/*.css\""
      }
    },

    "audit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node tools/scripts/audit-ui-components.mjs"
      }
    },

    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/ui-components",
        "command": "corepack pnpm run test"
      }
    },

    "storybook": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "libs/ui-components",
        "command": "corepack pnpm run storybook"
      }
    },

    "build-storybook": {
      "executor": "nx:run-commands",
      "dependsOn": ["@omnifex/ui-components:build"],
      "options": {
        "cwd": "libs/ui-components",
        "command": "corepack pnpm run build-storybook"
      }
    },

    "verify": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node tools/scripts/verify-ui-component.mjs --with-nx --fail-on-error"
      },
      "configurations": {
        "static": {
          "command": "node tools/scripts/verify-ui-component.mjs --static --fail-on-error"
        },
        "full": {
          "command": "node tools/scripts/verify-ui-component.mjs --with-nx --with-e2e --fail-on-error"
        },
        "button": {
          "command": "node tools/scripts/verify-ui-component.mjs --component=button --with-nx --fail-on-error"
        }
      }
    }
  },

  "tags": ["type:ui", "scope:public"]
}