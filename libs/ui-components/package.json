{
  "name": "@omnifex/ui-components",
  "version": "0.0.1",
  "description": "UI Components library built with StencilJS",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.js",
  "types": "./dist/src/public-api.d.ts",
  "collection": "./dist/collection/collection-manifest.json",
  "collection:main": "./dist/collection/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/public-api.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js",
      "default": "./loader/index.js"
    }
  },
  "files": [
    "dist/",
    "loader/",
    "README.md"
  ],
  "sideEffects": [
    "dist/**",
    "loader/**"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "jest --config jest.config.cjs",
    "test.e2e": "stencil test --e2e",
    "test.watch": "stencil test --spec --watch",
    "storybook": "storybook dev -p 6006 -c .storybook",
    "build-storybook": "storybook build -c .storybook -o ../../dist/storybook/ui-components"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@stencil/core": "^4.40.0",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/web-components": "^8.6.14",
    "@storybook/web-components-vite": "^8.6.14",
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "storybook": "^8.6.14",
    "vite": "^6.3.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rivoli-ai/omnifex-ui.git",
    "directory": "libs/ui-components"
  }
}