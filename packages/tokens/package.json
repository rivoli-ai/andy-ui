    "./andy-extras.css": "./dist/andy-extras.css",
    "./andy-shell.css": "./dist/andy-shell.css",
    "./src/*": "./src/*"
  },
  "scripts": {
    "build": "node build.mjs",
    "clean": "rm -rf dist"
  }
