{
  "name": "@andy-ui/tokens",
  "version": "0.1.0",
  "description": "Andy-UI design tokens and component stylesheet (framework-agnostic CSS).",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["*.css"],
  "publishConfig": { "access": "public" },
  "files": ["dist", "src"],
