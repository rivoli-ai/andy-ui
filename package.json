{
  "name": "andy-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Andy-UI — framework-agnostic component library (Lit web components + React & Angular wrappers).",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "storybook": "pnpm --filter @andy-ui/storybook storybook",
    "build-storybook": "pnpm --filter @andy-ui/storybook build-storybook",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
